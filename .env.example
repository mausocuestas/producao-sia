# Conexão Neon PostgreSQL — copie para .env e preencha. NUNCA commite o .env.
# Trocar de fornecedor (Supabase, Render, local) = mudar só esta linha.
DATABASE_URL="postgresql://usuario:senha@host.neon.tech/nome_do_banco?sslmode=require"

